# ─── App ──────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
INTERNAL_WEBHOOK_SECRET=                  # signing key for inbound webhooks (lead form)

# ─── Supabase ─────────────────────────────────────────────────────────────
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection used by Drizzle (server-side only).
# Use the "Direct connection" string for migrations and the pooled
# string (port 6543, ?pgbouncer=true) for runtime if you split them.
DATABASE_URL=postgres://postgres:password@localhost:5432/postgres

# ─── Vapi ─────────────────────────────────────────────────────────────────
VAPI_API_KEY=
VAPI_ORG_ID=
VAPI_ASSISTANT_TEMPLATE_ID=
VAPI_WEBHOOK_SECRET=

# ─── Twilio ───────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_DEFAULT_FROM_NUMBER=
# A2P 10DLC Messaging Service SID. provisionTenant attaches every new number
# to this service so SMS clears carrier filtering. Find at:
# Twilio Console → Messaging → Services → your service → "Service SID" (MGxxxx)
TWILIO_MESSAGING_SERVICE_SID=

# Demo provisioning. When both are set, every new tenant signup reuses these
# instead of buying a fresh Twilio number + registering with Vapi. Each tenant
# still gets a unique Vapi assistant; the shared number's assistant link is
# overwritten on each new signup (last-write-wins). Useful for letting friends
# test the onboarding flow without burning $1/mo per fake signup.
# Leave both empty in production.
DEMO_TWILIO_NUMBER=
DEMO_VAPI_PHONE_NUMBER_ID=

# ─── OpenRouter (summaries, intent classification) ────────────────────────
# Routed via OpenRouter using the OpenAI-compatible API.
# Get a key at https://openrouter.ai/
OPENROUTER_API_KEY=

# ─── Cal.com ──────────────────────────────────────────────────────────────
CAL_COM_API_KEY=

# ─── Stripe ───────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SETUP=
STRIPE_PRICE_MRR=

# ─── Inngest ──────────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Resend (owner email notifications) ───────────────────────────────────
# Optional. When unset, owner email notifications no-op silently — SMS still
# fires. Get a key at https://resend.com/api-keys.
RESEND_API_KEY=
# Verified sender, e.g. "Copper <noreply@yourdomain.com>". Falls back to a
# default if unset, but you'll want a verified domain in production.
NOTIFICATIONS_EMAIL_FROM=

# ─── Observability ────────────────────────────────────────────────────────
# Sentry — server-side error capture. Leave empty to disable. Get DSN at
# https://sentry.io/settings/[org]/projects/[project]/keys/
SENTRY_DSN=
# Same project as SENTRY_DSN, exposed to the browser for client errors.
NEXT_PUBLIC_SENTRY_DSN=
# Required only for build-time source-map upload (better stack traces).
# Create at https://sentry.io/settings/account/api/auth-tokens/ with
# project:read + project:releases + org:read scopes.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
