# ─── App ──────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
INTERNAL_WEBHOOK_SECRET=                  # signing key for inbound webhooks (lead form)

# ─── Supabase ─────────────────────────────────────────────────────────────
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection used by Drizzle (server-side only).
# Use the "Direct connection" string for migrations and the pooled
# string (port 6543, ?pgbouncer=true) for runtime if you split them.
DATABASE_URL=postgres://postgres:password@localhost:5432/postgres

# ─── Vapi ─────────────────────────────────────────────────────────────────
VAPI_API_KEY=
VAPI_ORG_ID=
VAPI_ASSISTANT_TEMPLATE_ID=
VAPI_WEBHOOK_SECRET=

# ─── Twilio ───────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_DEFAULT_FROM_NUMBER=

# ─── OpenRouter (summaries, intent classification) ────────────────────────
# Routed via OpenRouter using the OpenAI-compatible API.
# Get a key at https://openrouter.ai/
OPENROUTER_API_KEY=

# ─── Cal.com ──────────────────────────────────────────────────────────────
CAL_COM_API_KEY=

# ─── Stripe ───────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SETUP=
STRIPE_PRICE_MRR=

# ─── Inngest ──────────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Observability ────────────────────────────────────────────────────────
SENTRY_DSN=
