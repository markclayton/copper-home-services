# ─── App ──────────────────────────────────────────────────────────────────
# Local dev: http://localhost:3000
# Production: https://joincopper.io
APP_URL=http://localhost:3000
INTERNAL_WEBHOOK_SECRET=                  # signing key for inbound webhooks (lead form)

# Private-beta gate. Comma-separated emails allowed to create new accounts.
# Leave UNSET locally (gate off → anyone can sign up). In production, set to
# the tester roster to keep signups locked down until A2P 10DLC is approved.
# Existing tenants are grandfathered in regardless of this list.
# Example: SIGNUP_ALLOWLIST=mark.clayton93@gmail.com,tester1@example.com
SIGNUP_ALLOWLIST=

# ─── Supabase ─────────────────────────────────────────────────────────────
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection used by Drizzle (server-side only).
#
# DATABASE_URL — runtime queries from the app. Use Supabase's
#   "Transaction pooler" string (port 6543). Session mode (port 5432 on the
#   pooler host) is capped at 15 clients and Next.js exhausts it quickly
#   under parallel queries.
#   Example: postgres://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
#
# DIRECT_URL — used by drizzle-kit for migrations (db:generate / db:migrate
#   / db:push / db:studio). The transaction pooler strips prepared
#   statements which drizzle-kit needs, so migrations need a non-pooled
#   connection. Use either "Direct connection" or "Session pooler" string.
#   If DIRECT_URL is unset, drizzle-kit falls back to DATABASE_URL.
#   Example: postgres://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgres://postgres:password@localhost:5432/postgres
DIRECT_URL=

# ─── Vapi ─────────────────────────────────────────────────────────────────
VAPI_API_KEY=
VAPI_ORG_ID=
VAPI_ASSISTANT_TEMPLATE_ID=
VAPI_WEBHOOK_SECRET=

# ─── Twilio ───────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_DEFAULT_FROM_NUMBER=
# A2P 10DLC Messaging Service SID. provisionTenant attaches every new number
# to this service so SMS clears carrier filtering. Find at:
# Twilio Console → Messaging → Services → your service → "Service SID" (MGxxxx)
TWILIO_MESSAGING_SERVICE_SID=

# Demo provisioning. When both are set, every new tenant signup reuses these
# instead of buying a fresh Twilio number + registering with Vapi. Each tenant
# still gets a unique Vapi assistant; the shared number's assistant link is
# overwritten on each new signup (last-write-wins). Useful for letting friends
# test the onboarding flow without burning $1/mo per fake signup.
# Leave both empty in production.
DEMO_TWILIO_NUMBER=
DEMO_VAPI_PHONE_NUMBER_ID=

# ─── OpenRouter (summaries, intent classification) ────────────────────────
# Routed via OpenRouter using the OpenAI-compatible API.
# Get a key at https://openrouter.ai/
OPENROUTER_API_KEY=

# ─── Cal.com ──────────────────────────────────────────────────────────────
CAL_COM_API_KEY=

# ─── Stripe ───────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SETUP=
STRIPE_PRICE_MRR=

# ─── Inngest ──────────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Resend (owner email notifications) ───────────────────────────────────
# Optional. When unset, owner email notifications no-op silently — SMS still
# fires. Get a key at https://resend.com/api-keys.
RESEND_API_KEY=
# Verified sender. Production should use the notifications subdomain that's
# verified in Resend, e.g. "Copper <hello@notifications.joincopper.io>".
# Falls back to a default if unset.
NOTIFICATIONS_EMAIL_FROM=

# ─── Observability ────────────────────────────────────────────────────────
# Sentry — server-side error capture. Leave empty to disable. Get DSN at
# https://sentry.io/settings/[org]/projects/[project]/keys/
SENTRY_DSN=
# Same project as SENTRY_DSN, exposed to the browser for client errors.
NEXT_PUBLIC_SENTRY_DSN=
# Required only for build-time source-map upload (better stack traces).
# Create at https://sentry.io/settings/account/api/auth-tokens/ with
# project:read + project:releases + org:read scopes.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
